# Gemini API key — used by backend scrapers for sentiment analysis and the
# frontend AI chat widget. In Vercel, add under Project Settings -> Environment Variables.
VITE_GEMINI_API_KEY=MY_GEMINI_API_KEY
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Twitter / X credentials (choose one approach)
TWITTER_USERNAME=your_username
TWITTER_EMAIL=your_email@example.com
TWITTER_PASSWORD=your_password
TWITTER_BEARER_TOKEN=your_bearer_token   # Official API (preferred)
TWITTER_AUTH_TOKEN=your_auth_token       # Browser cookie fallback
TWITTER_CT0=your_ct0                     # Browser cookie fallback

# Facebook cookies (from browser DevTools -> Application -> Cookies -> facebook.com)
FACEBOOK_C_USER=your_c_user
FACEBOOK_XS=your_xs
FACEBOOK_DATR=your_datr

# Quora: no Quora account needed — public pages scraped via Playwright.
# Optional but recommended: Serper.dev for smarter targeted URL discovery.
#   FREE tier: 2,500 searches/month, no credit card required.
#   Sign up in 30 seconds at: https://serper.dev → Dashboard → copy API key
#   NOTE: Google Custom Search API is CLOSED to new users (deprecated Jan 2027).
SERPER_API_KEY=your_serper_api_key
